# Comms — Environment Variables
# Copy this file to .env.local and fill in your values.

# ─── AI Models ───
GOOGLE_GENERATIVE_AI_API_KEY=
OPENAI_API_KEY=

# ─── Twilio Voice ───
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ─── Public URLs ───
# For local dev: use cloudflared tunnel URLs
# For production: set in Fly.io secrets / fly.toml
NEXT_PUBLIC_APP_URL=http://localhost:3000
VOICE_WS_HOST=localhost:8765

# ─── Google OAuth (Gmail integration) ───
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ─── Convex (optional) ───
# CONVEX_DEPLOYMENT=

# ─── LiveKit (optional — voice agent pipeline) ───
# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=

# ─── Deepgram STT (optional) ───
# DEEPGRAM_API_KEY=

# ─── Cartesia TTS (optional) ───
# CARTESIA_API_KEY=
