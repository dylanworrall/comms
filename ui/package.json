{
  "name": "@soshilabs/comms",
  "version": "0.1.2",
  "main": "./dist/tools.cjs",
  "files": [
    "dist/",
    "soshi.manifest.json"
  ],
  "scripts": {
    "build:tools": "esbuild src/lib/ai/tools/index.ts --bundle --outfile=dist/tools.cjs --platform=node --format=cjs --external:googleapis --external:@ai-sdk/* --external:ai --external:zod",
    "dev": "next dev --turbopack",
    "dev:voice": "npx tsx voice-server.ts",
    "dev:agent": "npx tsx livekit-agent.ts dev",
    "dev:all": "npx concurrently \"npm run dev\" \"npm run dev:agent\"",
    "build": "next build",
    "start": "next start",
    "start:voice": "npx tsx voice-server.ts",
    "deploy:web": "fly deploy -c fly.toml",
    "deploy:voice": "fly deploy -c fly.voice.toml"
  },
